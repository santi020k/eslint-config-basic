# GitHub Personal Access Token — used by the release workflow to create
# GitHub Releases and push changelog commits. Requires `repo` scope.
PA_TOKEN=

# npm Access Token — used by the publish workflow to publish the
# @santi020k/eslint-config-basic package to the npm registry.
# Generate at https://www.npmjs.com/settings/<user>/tokens
NPM_TOKEN=

# Turbo Token — used by the build workflow to cache dependencies.
TURBO_TOKEN=

# Turbo Team — used by the build workflow to cache dependencies.
TURBO_TEAM=

# Turbo Optimization
# Limits parallel requests to avoid 429 Too Many Requests
TURBO_CONCURRENCY=10
# Timeout for remote cache operations in seconds
TURBO_REMOTE_CACHE_TIMEOUT=30
