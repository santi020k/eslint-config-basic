{
  "name": "@santi020k/eslint-config-astro",
  "version": "1.3.0",
  "description": "Astro ESLint configuration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "@santi020k/eslint-config-core": "workspace:^",
    "eslint-plugin-astro": "^1.7.0"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.58.2",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/astro"
  },
  "homepage": "https://eslint.santi020k.com/frameworks/astro.html",
  "bugs": {
    "url": "https://github.com/santi020k/eslint-config-basic/issues"
  }
}
