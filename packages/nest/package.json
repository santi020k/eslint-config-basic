{
  "name": "@santi020k/eslint-config-nest",
  "version": "0.2.2",
  "description": "NestJS ESLint configuration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint"
  },
  "peerDependencies": {
    "eslint": "^10.0.3"
  },
  "dependencies": {
    "@santi020k/eslint-config-core": "*",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.26"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.57.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/nest"
  }
}
