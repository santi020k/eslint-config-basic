{
  "name": "@santi020k/eslint-config-basic",
  "version": "0.8.1",
  "description": "A comprehensive ESLint configuration package for JavaScript, TypeScript, and React projects.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:pack": "npm pack",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint",
    "prepack": "rm -f README.md && cp ../../README.md ./README.md",
    "postpack": "rm -f README.md && ln -s ../../README.md ./README.md",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "basic-eslint": "./dist/cli.js"
  },
  "dependencies": {
    "@santi020k/eslint-config-core": "^1.0.0",
    "@santi020k/eslint-config-optionals": "^1.0.0",
    "@santi020k/eslint-config-typescript": "^1.0.0",
    "eslint": "^10.0.3",
    "typescript-eslint": "^8.24.1"
  },
  "peerDependencies": {
    "@santi020k/eslint-config-angular": "^1.0.0",
    "@santi020k/eslint-config-astro": "^1.0.0",
    "@santi020k/eslint-config-expo": "^1.0.0",
    "@santi020k/eslint-config-nest": "^1.0.0",
    "@santi020k/eslint-config-next": "^1.0.0",
    "@santi020k/eslint-config-react": "^1.0.0",
    "@santi020k/eslint-config-solid": "^1.0.0",
    "@santi020k/eslint-config-svelte": "^1.0.0",
    "@santi020k/eslint-config-vue": "^1.0.0",
    "eslint": "^10.0.3"
  },
  "peerDependenciesMeta": {
    "@santi020k/eslint-config-angular": {
      "optional": true
    },
    "@santi020k/eslint-config-astro": {
      "optional": true
    },
    "@santi020k/eslint-config-expo": {
      "optional": true
    },
    "@santi020k/eslint-config-nest": {
      "optional": true
    },
    "@santi020k/eslint-config-next": {
      "optional": true
    },
    "@santi020k/eslint-config-react": {
      "optional": true
    },
    "@santi020k/eslint-config-solid": {
      "optional": true
    },
    "@santi020k/eslint-config-svelte": {
      "optional": true
    },
    "@santi020k/eslint-config-vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@typescript-eslint/utils": "^8.57.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/basic"
  }
}
