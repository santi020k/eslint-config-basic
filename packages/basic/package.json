{
  "name": "@santi020k/eslint-config-basic",
  "version": "0.8.1",
  "description": "A composable ESLint 9/10+ Flat Config package for JavaScript, TypeScript, React, Next.js, Vue, Svelte, Solid, Angular, Astro, Expo, NestJS, Qwik, and Remix.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:pack": "npm pack",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint",
    "prepack": "rm -f README.md && cp ../../README.md ./README.md",
    "postpack": "rm -f README.md && ln -s ../../README.md ./README.md",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "basic-eslint": "./dist/cli.js"
  },
  "dependencies": {
    "@santi020k/eslint-config-core": "workspace:^",
    "@santi020k/eslint-config-optionals": "workspace:^",
    "@santi020k/eslint-config-typescript": "workspace:^",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "@santi020k/eslint-config-angular": "workspace:^",
    "@santi020k/eslint-config-astro": "workspace:^",
    "@santi020k/eslint-config-expo": "workspace:^",
    "@santi020k/eslint-config-nest": "workspace:^",
    "@santi020k/eslint-config-next": "workspace:^",
    "@santi020k/eslint-config-react": "workspace:^",
    "@santi020k/eslint-config-solid": "workspace:^",
    "@santi020k/eslint-config-svelte": "workspace:^",
    "@santi020k/eslint-config-vue": "workspace:^",
    "@santi020k/eslint-config-qwik": "workspace:^",
    "@santi020k/eslint-config-remix": "workspace:^",
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@santi020k/eslint-config-angular": {
      "optional": true
    },
    "@santi020k/eslint-config-astro": {
      "optional": true
    },
    "@santi020k/eslint-config-expo": {
      "optional": true
    },
    "@santi020k/eslint-config-nest": {
      "optional": true
    },
    "@santi020k/eslint-config-next": {
      "optional": true
    },
    "@santi020k/eslint-config-react": {
      "optional": true
    },
    "@santi020k/eslint-config-solid": {
      "optional": true
    },
    "@santi020k/eslint-config-svelte": {
      "optional": true
    },
    "@santi020k/eslint-config-vue": {
      "optional": true
    },
    "@santi020k/eslint-config-qwik": {
      "optional": true
    },
    "@santi020k/eslint-config-remix": {
      "optional": true
    }
  },
  "devDependencies": {
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@typescript-eslint/utils": "^8.57.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/basic"
  }
}
