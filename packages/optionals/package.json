{
  "name": "@santi020k/eslint-config-optionals",
  "version": "1.2.0",
  "description": "Optional ESLint configurations for various tools and frameworks",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "@santi020k/eslint-config-core": "workspace:*",
    "@cspell/eslint-plugin": "^9.7.0",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.27",
    "@eslint/compat": "^2.0.3",
    "@eslint/markdown": "^8.0.1",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@stencil-community/eslint-plugin": "^0.10.0",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-testing-library": "^7.16.1",
    "eslint-plugin-toml": "^1.3.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "publint": "^0.3.18",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@typescript-eslint/utils": "^8.57.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/optionals"
  }
}
