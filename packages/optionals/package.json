{
  "name": "@santi020k/eslint-config-optionals",
  "version": "0.4.2",
  "description": "Optional ESLint configurations for various tools and frameworks",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint"
  },
  "peerDependencies": {
    "eslint": "^10.0.3"
  },
  "dependencies": {
    "eslint-plugin-sonarjs": "^4.0.2",
    "@cspell/eslint-plugin": "^9.7.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/markdown": "^7.5.1",
    "@nestjs/swagger": "11.2.6",
    "@stencil-community/eslint-plugin": "^0.10.0",
    "@vitest/eslint-plugin": "^1.6.11",
    "cross-dirname": "^0.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.57.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/optionals"
  }
}
