{
  "name": "@santi020k/eslint-config-react",
  "version": "0.1.0",
  "description": "React ESLint configuration with hooks and JSX rules",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint"
  },
  "peerDependencies": {
    "eslint": "^10.0.3",
    "react": ">=19.2.4"
  },
  "dependencies": {
    "@santi020k/eslint-config-core": "workspace:*",
    "@eslint/compat": "^2.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.57.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/react"
  }
}
