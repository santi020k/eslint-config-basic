{
  "name": "@santi020k/eslint-config-qwik",
  "version": "1.5.0",
  "description": "Qwik ESLint configuration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check:exports": "publint",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "eslint-plugin-qwik": "^1.11.0"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.59.0",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "license": "MIT",
  "author": "santi020k",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/qwik"
  },
  "homepage": "https://eslint.santi020k.com/frameworks/qwik.html",
  "bugs": {
    "url": "https://github.com/santi020k/eslint-config-basic/issues"
  }
}
