{
  "name": "@santi020k/eslint-config-docs",
  "private": true,
  "version": "1.4.0",
  "description": "VitePress documentation site for the @santi020k/eslint-config-basic monorepo",
  "type": "module",
  "scripts": {
    "docs:build": "vitepress build .",
    "docs:dev": "vitepress dev .",
    "docs:preview": "vitepress preview .",
    "docs:clean": "rm -rf .vitepress/dist .vitepress/cache api/reference",
    "build": "echo \"No direct build step required\"",
    "dev": "echo \"No direct build step required\"",
    "clean": "rm -rf dist node_modules",
    "check:exports": "echo \"No exports to check\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "author": "santi020k",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git",
    "directory": "packages/docs"
  }
}
