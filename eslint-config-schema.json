{
  "$ref": "#/definitions/EslintConfigOptions",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CacheDurationSeconds": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "const": "Infinity",
          "type": "string"
        }
      ]
    },
    "DebugLevel": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "items": {
            "enum": [
              "eslint",
              "typescript",
              "typescript-eslint"
            ],
            "type": "string"
          },
          "type": "array"
        }
      ]
    },
    "DetectedFrameworkName": {
      "description": "Framework names that can be auto-detected by `detectProjectOptions`. These are informational only — you still need to import and pass the actual framework config via `frameworks.<name>` in `eslintConfig()`.",
      "enum": [
        "react",
        "next",
        "astro",
        "expo",
        "vue",
        "svelte",
        "solid",
        "angular",
        "nest",
        "hono",
        "qwik",
        "remix"
      ],
      "type": "string"
    },
    "EcmaVersion": {
      "anyOf": [
