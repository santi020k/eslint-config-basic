    "LooseRuleCreateFunction": {
      "$comment": "(context: any) => Record<string, Function | undefined>",
      "properties": {
        "namedArgs": {
          "additionalProperties": false,
          "properties": {
            "context": {}
          },
          "required": [
            "context"
          ],
          "type": "object"
        }
      },
      "type": "object"
    },
    "LooseRuleDefinition": {
      "anyOf": [
        {
          "$ref": "#/definitions/LooseRuleCreateFunction"
        },
        {
          "additionalProperties": false,
          "properties": {
            "create": {
              "$ref": "#/definitions/LooseRuleCreateFunction"
            },
            "meta": {
              "type": "object"
            }
          },
          "required": [
            "create"
          ],
          "type": "object"
        }
      ],
      "description": "A loose definition of the RuleModule type for use with configs. This type is intended to relax validation of types so that we can have basic validation without being overly strict about nitty gritty details matching.\n\nFor example the plugin might be declared using an old version of our types or they might use the DefinitelyTyped eslint types. Ultimately we don't need super strict validation in a config - a loose shape match is \"good enough\" to help validate the config is correct."
    },
    "NextMode": {
      "description": "Enum for Next.js mode options",
      "enum": [
        "pages",
        "app-router"
      ],
      "type": "string"
    },
    "Parser.LooseParserModule": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "meta": {
              "additionalProperties": false,
              "description": "Information about the parser to uniquely identify it when serializing.",
              "properties": {
                "name": {
                  "description": "The unique name of the parser.",
                  "type": "string"
                },
                "version": {
                  "description": "The a string identifying the version of the parser.",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "parseForESLint": {
              "additionalProperties": false,
              "properties": {
                "ast": {},
                "scopeManager": {},
                "services": {},
                "visitorKeys": {}
              },
              "required": [
                "ast",
                "scopeManager",
                "services",
                "visitorKeys"
              ],
              "type": "object"
            }
          },
          "required": [
            "parseForESLint"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "meta": {
              "additionalProperties": false,
              "description": "Information about the parser to uniquely identify it when serializing.",
              "properties": {
                "name": {
                  "description": "The unique name of the parser.",
                  "type": "string"
                },
                "version": {
                  "description": "The a string identifying the version of the parser.",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "parse": {}
          },
          "required": [
            "parse"
          ],
          "type": "object"
        }
      ],
      "description": "A loose definition of the ParserModule type for use with configs This type intended to relax validation of configs so that parsers that have different AST types or scope managers can still be passed to configs"
    },
    "ParserOptions": {
      "additionalProperties": {},
      "properties": {
        "cacheLifetime": {
          "additionalProperties": false,
          "properties": {
            "glob": {
              "$ref": "#/definitions/CacheDurationSeconds"
            }
          },
          "type": "object"
        },
        "debugLevel": {
