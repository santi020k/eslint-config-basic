          "const": 13,
          "type": "number"
        },
        {
          "const": 14,
          "type": "number"
        },
        {
          "const": 15,
          "type": "number"
        },
        {
          "const": 16,
          "type": "number"
        },
        {
          "const": 17,
          "type": "number"
        },
        {
          "const": 2015,
          "type": "number"
        },
        {
          "const": 2016,
          "type": "number"
        },
        {
          "const": 2017,
          "type": "number"
        },
        {
          "const": 2018,
          "type": "number"
        },
        {
          "const": 2019,
          "type": "number"
        },
        {
          "const": 2020,
          "type": "number"
        },
        {
          "const": 2021,
          "type": "number"
        },
        {
          "const": 2022,
          "type": "number"
        },
        {
          "const": 2023,
          "type": "number"
        },
        {
          "const": 2024,
          "type": "number"
        },
        {
          "const": 2025,
          "type": "number"
        },
        {
          "const": 2026,
          "type": "number"
        },
        {
          "const": "latest",
          "type": "string"
        },
        {
          "not": {}
        }
      ]
    },
    "EslintConfigOptions": {
      "additionalProperties": false,
      "description": "ESLint configuration interface",
      "properties": {
        "detectedFrameworks": {
          "description": "Frameworks detected from package.json by `detectProjectOptions()`. This is informational — use it to display what was auto-detected. To actually enable framework linting you still need to import the framework package and pass it via `frameworks.<name>`.",
          "items": {
            "$ref": "#/definitions/DetectedFrameworkName"
          },
          "type": "array"
        },
        "extensions": {
          "description": "List of specialized ESLint rules and extensions",
          "items": {
            "$ref": "#/definitions/Extension"
          },
          "type": "array"
        },
        "formats": {
          "description": "Additional non-JS/TS file formats to lint",
          "items": {
            "$ref": "#/definitions/Format"
          },
          "type": "array"
        },
        "frameworks": {
          "additionalProperties": false,
          "description": "Framework and library specific configurations. Each value must be the imported config from the corresponding `@santi020k/eslint-config-<framework>` package — boolean values are not accepted.",
          "properties": {
            "angular": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "astro": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "expo": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "hono": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "nest": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "next": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "qwik": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "react": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "remix": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "solid": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "svelte": {
              "$ref": "#/definitions/ImportedFramework"
            },
            "vue": {
              "$ref": "#/definitions/ImportedFramework"
            }
          },
          "type": "object"
        },
        "libraries": {
          "description": "List of application-level dependencies configurations",
          "items": {
            "$ref": "#/definitions/Library"
          },
          "type": "array"
        },
        "nextMode": {
          "$ref": "#/definitions/NextMode",
          "description": "Next.js specific routing mode"
        },
        "preset": {
          "$ref": "#/definitions/Preset",
          "description": "High-level configuration preset"
        },
        "runtime": {
          "$ref": "#/definitions/Runtime",
          "description": "Runtime environment preset (Node, Browser, Universal)"
        },
        "settings": {
          "description": "List of global settings and behavioral flags",
          "items": {
            "$ref": "#/definitions/Setting"
          },
          "type": "array"
        },
        "strict": {
          "description": "If true, all 'warn' rules are promoted to 'error'",
          "type": "boolean"
        },
        "testing": {
          "description": "List of testing frameworks and testing environments",
          "items": {
            "$ref": "#/definitions/Testing"
          },
          "type": "array"
        },
        "tools": {
          "description": "List of integrations for external standalone tools",
          "items": {
            "$ref": "#/definitions/Tool"
          },
          "type": "array"
        },
        "tsconfigRootDir": {
          "description": "Root directory of the project. Required if multiple candidate TSConfigRootDirs are present.",
          "type": "string"
        },
        "typescript": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "#/definitions/TsOptions"
            }
          ],
          "description": "Enable TypeScript support with optional settings"
        }
      },
      "type": "object"
    },
    "Extension": {
      "description": "Enum for specialized ESLint extensions and strict rule sets",
      "enum": [
        "regexp",
        "unicorn",
        "sonarjs",
        "security",
        "perfectionist",
        "best-practices"
      ],
      "type": "string"
    },
    "FlatConfig.Config": {
      "additionalProperties": false,
      "properties": {
        "basePath": {
          "description": "The base path for files and ignores.\n\nNote that this is not permitted inside an `extends` array.\n\nSince ESLint 9.30.0",
          "type": "string"
        },
        "files": {
          "description": "An array of glob patterns indicating the files that the configuration object should apply to. If not specified, the configuration object applies to all files matched by any other configuration object.",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            ]
          },
          "type": "array"
        },
        "ignores": {
          "description": "An array of glob patterns indicating the files that the configuration object should not apply to. If not specified, the configuration object applies to all files matched by files.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "language": {
          "description": "Language specifier in the form `namespace/language-name` where `namespace` is a plugin name set in the `plugins` field.",
          "type": "string"
        },
        "languageOptions": {
          "$ref": "#/definitions/FlatConfig.LanguageOptions",
          "description": "An object containing settings related to how JavaScript is configured for linting."
        },
        "linterOptions": {
          "$ref": "#/definitions/FlatConfig.LinterOptions",
          "description": "An object containing settings related to the linting process."
        },
        "name": {
          "description": "An string to identify the configuration object. Used in error messages and inspection tools.",
          "type": "string"
        },
        "plugins": {
          "$ref": "#/definitions/FlatConfig.Plugins",
          "description": "An object containing a name-value mapping of plugin names to plugin objects. When `files` is specified, these plugins are only available to the matching files."
        },
        "processor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/FlatConfig.Processor"
            }
          ],
          "description": "Either an object containing `preprocess()` and `postprocess()` methods or a string indicating the name of a processor inside of a plugin (i.e., `\"pluginName/processorName\"`)."
        },
        "rules": {
          "$ref": "#/definitions/FlatConfig.Rules",
          "description": "An object containing the configured rules. When `files` or `ignores` are specified, these rule configurations are only available to the matching files."
        },
        "settings": {
          "$ref": "#/definitions/FlatConfig.Settings",
          "description": "An object containing name-value pairs of information that should be available to all rules."
        }
      },
      "type": "object"
    },
    "FlatConfig.ConfigArray": {
      "items": {
        "$ref": "#/definitions/FlatConfig.Config"
      },
      "type": "array"
    },
    "FlatConfig.EcmaVersion": {
      "$ref": "#/definitions/EcmaVersion"
    },
    "FlatConfig.GlobalsConfig": {
      "$ref": "#/definitions/SharedConfig.GlobalsConfig"
    },
    "FlatConfig.LanguageOptions": {
      "additionalProperties": false,
      "properties": {
        "ecmaVersion": {
          "$ref": "#/definitions/FlatConfig.EcmaVersion",
          "default": "latest",
          "description": "The version of ECMAScript to support. May be any year (i.e., `2022`) or version (i.e., `5`). Set to `\"latest\"` for the most recent supported version."
        },
        "globals": {
          "$ref": "#/definitions/FlatConfig.GlobalsConfig",
          "description": "An object specifying additional objects that should be added to the global scope during linting."
        },
        "parser": {
          "$ref": "#/definitions/FlatConfig.Parser",
          "default": "```\n// https://github.com/eslint/espree\nrequire('espree')\n```",
          "description": "An object containing a `parse()` method or a `parseForESLint()` method."
        },
        "parserOptions": {
          "$ref": "#/definitions/FlatConfig.ParserOptions",
          "description": "An object specifying additional options that are passed directly to the parser. The available options are parser-dependent."
        },
        "sourceType": {
          "$ref": "#/definitions/FlatConfig.SourceType",
          "default": "```\n// for `.js` and `.mjs` files\n\"module\"\n// for `.cjs` files\n\"commonjs\"\n```",
          "description": "The type of JavaScript source code. Possible values are `\"script\"` for traditional script files, `\"module\"` for ECMAScript modules (ESM), and `\"commonjs\"` for CommonJS files."
        }
      },
      "type": "object"
    },
    "FlatConfig.LinterOptions": {
      "additionalProperties": false,
      "properties": {
        "noInlineConfig": {
          "description": "A Boolean value indicating if inline configuration is allowed.",
          "type": "boolean"
        },
        "reportUnusedDisableDirectives": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "#/definitions/SharedConfig.Severity"
            },
            {
              "$ref": "#/definitions/SharedConfig.SeverityString"
            }
          ],
          "default": "warn",
          "description": "A severity string indicating if and how unused disable and enable directives should be tracked and reported. For legacy compatibility, `true` is equivalent to `\"warn\"` and `false` is equivalent to `\"off\"`."
        },
        "reportUnusedInlineConfigs": {
          "anyOf": [
            {
              "$ref": "#/definitions/SharedConfig.Severity"
            },
            {
              "$ref": "#/definitions/SharedConfig.SeverityString"
            }
          ],
          "default": "off",
          "description": "A severity string indicating if and how unused inline directives should be tracked and reported.\n\nsince ESLint 9.19.0"
        }
      },
      "type": "object"
    },
    "FlatConfig.Parser": {
      "$ref": "#/definitions/Parser.LooseParserModule"
    },
    "FlatConfig.ParserOptions": {
      "$ref": "#/definitions/SharedConfig.ParserOptions"
    },
    "FlatConfig.Plugins": {
      "additionalProperties": {
        "additionalProperties": false,
        "description": "We intentionally omit the `configs` key from this object because it avoids type conflicts with old plugins that haven't updated their configs to flat configs yet. It's valid to reference these old plugins because ESLint won't access the `.config` property of a plugin when evaluating a flat config.",
        "properties": {
          "meta": {
            "additionalProperties": false,
            "description": "Metadata about your plugin for easier debugging and more effective caching of plugins.",
            "properties": {
              "name": {
                "description": "The meta.name property should match the npm package name for your plugin.",
                "type": "string"
              },
              "namespace": {
                "description": "If you followed the classic style to name your package (e.g. `eslint-plugin-X`, `@X/eslint-plugin`, or `@X/eslint-plugin-Y`), then this should match the classic namespace inferred for your package (e.g. `X`, `@X`, or `@X/Y`, respectively).",
                "type": "string"
              },
              "version": {
                "description": "The meta.version property should match the npm package version for your plugin.",
                "type": "string"
              }
            },
            "type": "object"
          },
          "processors": {
            "additionalProperties": {
              "$ref": "#/definitions/FlatConfig.Processor"
            },
            "description": "The definition of plugin processors. Users can stringly reference the processor using the key in their config (i.e., `\"pluginName/processorName\"`).",
            "type": "object"
          },
          "rules": {
            "additionalProperties": {
              "$ref": "#/definitions/LooseRuleDefinition"
            },
            "description": "The definition of plugin rules. The key must be the name of the rule that users will use Users can stringly reference the rule using the key they registered the plugin under combined with the rule name. i.e. for the user config `plugins: { foo: pluginReference }` - the reference would be `\"foo/ruleName\"`.",
            "type": "object"
          }
        },
        "type": "object"
      },
      "type": "object"
    },
    "FlatConfig.Processor": {
      "$ref": "#/definitions/Processor.LooseProcessorModule"
    },
    "FlatConfig.Rules": {
      "$ref": "#/definitions/SharedConfig.RulesRecord"
    },
    "FlatConfig.Settings": {
      "$ref": "#/definitions/SharedConfigurationSettings"
    },
    "FlatConfig.SourceType": {
      "anyOf": [
        {
          "const": "commonjs",
          "type": "string"
        },
        {
          "$ref": "#/definitions/SourceType"
        }
      ]
    },
    "FlatConfigArray": {
      "$ref": "#/definitions/FlatConfig.ConfigArray",
      "description": "Type alias for ESLint flat config array"
    },
    "Format": {
      "description": "Enum for linting non-JS/TS file formats",
      "enum": [
        "mdx",
        "markdown",
        "jsonc",
        "yaml",
        "toml",
        "graphql"
      ],
      "type": "string"
    },
    "ImportedFramework": {
      "anyOf": [
        {
          "$ref": "#/definitions/FlatConfigArray"
        },
        {
          "additionalProperties": false,
          "properties": {
            "default": {
              "anyOf": [
                {
                  "$ref": "#/definitions/FlatConfigArray"
                },
                {
                  "$comment": "(options?: Record<string, unknown>) => FlatConfigArray",
                  "properties": {
                    "namedArgs": {
                      "additionalProperties": false,
                      "properties": {
                        "options": {
                          "additionalProperties": {},
                          "type": "object"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              ]
            }
          },
          "required": [
            "default"
          ],
          "type": "object"
        },
        {
          "$comment": "(options?: Record<string, unknown>) => FlatConfigArray",
          "properties": {
            "namedArgs": {
              "additionalProperties": false,
              "properties": {
                "options": {
                  "additionalProperties": {},
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        }
      ],
      "description": "Type to handle both direct config arrays and imported modules with a default export. User-facing framework options should always pass imported config arrays/modules explicitly — boolean values are not accepted and will throw a descriptive error."
    },
    "JSDocParsingMode": {
      "enum": [
