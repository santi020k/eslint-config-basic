{
  "name": "@santi020k/eslint-config-basic-root",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://santi020k.github.io/eslint-config-basic/",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@10.8.3",
  "workspaces": [
    "packages/*",
    "packages/playground/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "npm run build && vitest run packages/tests",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky config/.husky",
    "pre-commit": "lint-staged",
    "pre-push": "npm run test && npm run lint && npm run build && npm run check:exports",
    "docs": "typedoc",
    "docs:md": "typedoc --options typedoc.markdown.mjs",
    "docs:clean": "rm -rf docs docs-md",
    "check:exports": "turbo run check:exports",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "publint": "^0.3.18",
    "turbo": "^2.8.18",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md}": [
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "eslint": "$eslint",
    "eslint-config-standard": "$eslint-config-standard",
    "eslint-plugin-promise": "$eslint-plugin-promise",
    "eslint-plugin-n": "$eslint-plugin-n"
  }
}
