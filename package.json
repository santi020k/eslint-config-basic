{
  "name": "@santi020k/eslint-config-basic-root",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://eslint.santi020k.me/",
  "version": "0.8.1",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:spell": "cspell \"**\" --gitignore --cache --show-suggestions --show-context",
    "lint:knip": "knip",
    "test": "pnpm run build && pnpm --filter @santi020k/eslint-config-tests run test",
    "test:coverage": "pnpm run build && pnpm --filter @santi020k/eslint-config-tests run test:coverage",
    "check:exports": "turbo run check:exports",
    "inspector": "eslint-config-inspector",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky config/.husky",
    "ok": "pnpm install --reporter=silent && TURBO_LOG_ORDER=grouped pnpm run build && pnpm run test --silent && TURBO_LOG_ORDER=grouped pnpm run lint && TURBO_LOG_ORDER=grouped pnpm run typecheck",
    "pre-commit": "lint-staged",
    "pre-push": "pnpm run lint:knip && pnpm run test && pnpm run lint && pnpm run build && pnpm run check:exports",
    "docs": "npm run docs:build",
    "docs:api": "typedoc --options typedoc.markdown.mjs",
    "docs:build": "pnpm run docs:api && pnpm --filter @santi020k/eslint-config-docs run docs:build",
    "build:schema": "ts-json-schema-generator -p packages/core/src/types.ts -t EslintConfigOptions -o eslint-config-schema.json",
    "docs:dev": "pnpm run docs:api && pnpm --filter @santi020k/eslint-config-docs run docs:dev",
    "docs:preview": "pnpm --filter @santi020k/eslint-config-docs run docs:preview",
    "docs:md": "npm run docs:api",
    "docs:sync-readmes": "node scripts/generate-package-readmes.mjs",
    "docs:clean": "pnpm --filter @santi020k/eslint-config-docs run docs:clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/config-inspector": "^1.5.0",
    "@santi020k/eslint-config-basic": "workspace:^",
    "@types/node": "^22.10.1",
    "cspell": "^9.7.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "knip": "^6.2.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.2",
    "ts-json-schema-generator": "^2.9.0",
    "turbo": "^2.9.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "eslint": "$eslint",
      "glob": "^11.0.0",
      "rimraf": "^6.0.0"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json,yaml,yml}": [
      "cspell --no-must-find-files"
    ],
    "*.{js,jsx,ts,tsx,md}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "author": "santi020k"
}
