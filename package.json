{
  "name": "@santi020k/eslint-config-basic-root",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://santi020k.github.io/eslint-config-basic/",
  "version": "0.7.1",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "npm@10.8.3",
  "workspaces": [
    "packages/*",
    "packages/playground/*",
    "packages/playground/libraries/*",
    "packages/playground/testing/*",
    "packages/playground/formats/*",
    "packages/playground/tools/*",
    "packages/playground/extensions/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/eslint-config-basic.git"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "inspector": "eslint-config-inspector",
    "test": "npm run build && vitest run packages/tests",
    "test:coverage": "npm run build && vitest run packages/tests --coverage",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky config/.husky",
    "lint:spell": "cspell \"**\" --gitignore --cache --show-suggestions --show-context",
    "lint:knip": "knip",
    "pre-commit": "lint-staged",
    "pre-push": "npm run test && npm run lint && npm run build && npm run check:exports",
    "docs": "npm run docs:build",
    "docs:api": "typedoc --options typedoc.markdown.mjs",
    "docs:build": "npm run docs:api && npm run docs:build -w packages/docs",
    "docs:dev": "npm run docs:api && npm run docs:dev -w packages/docs",
    "docs:preview": "npm run docs:preview -w packages/docs",
    "docs:md": "npm run docs:api",
    "docs:sync-readmes": "node scripts/generate-package-readmes.mjs",
    "docs:clean": "npm run docs:clean -w packages/docs",
    "check:exports": "turbo run check:exports",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/config-inspector": "^1.5.0",
    "@santi020k/eslint-config-basic": "workspace:*",
    "@types/node": "^22.10.1",
    "commitizen": "^4.3.1",
    "cspell": "^9.7.0",
    "cz-conventional-changelog": "^3.3.0",
    "@typescript-eslint/utils": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "husky": "^9.1.7",
    "knip": "^6.0.0",
    "lint-staged": "^16.4.0",
    "publint": "^0.3.18",
    "turbo": "^2.8.18",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "tailwindcss": "^3.4.17",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json,yaml,yml}": [
      "cspell --no-must-find-files"
    ],
    "*.{js,jsx,ts,tsx,md}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "eslint": "$eslint",
    "**": {
      "eslint": "$eslint"
    },
    "eslint-config-standard": "$eslint-config-standard",
    "eslint-plugin-promise": {
      ".": "$eslint-plugin-promise",
      "eslint": "$eslint"
    },
    "eslint-plugin-n": {
      ".": "$eslint-plugin-n",
      "eslint": "$eslint"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    },
    "eslint-plugin-solid": {
      "eslint": "$eslint"
    },
    "eslint-plugin-svelte": {
      "eslint": "$eslint"
    },
    "eslint-plugin-vue": {
      "eslint": "$eslint"
    },
    "eslint-plugin-astro": {
      "eslint": "$eslint"
    },
    "eslint-plugin-expo": {
      "eslint": "$eslint"
    },
    "eslint-plugin-unicorn": {
      "eslint": "$eslint"
    },
    "eslint-plugin-import-x": {
      "eslint": "$eslint"
    },
    "@next/eslint-plugin-next": {
      "eslint": "$eslint"
    },
    "@angular-eslint/eslint-plugin": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/utils": "^8.57.1"
  }
}
