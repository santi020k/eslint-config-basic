{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["packages/*/src/**/*.ts"],
  "ignore": [
    "**/*.d.ts",
    "**/dist/**",
    "packages/playground/**",
    "config/docs-packages.mjs",
    "typedoc.markdown.mjs"
  ],
  "ignoreDependencies": [
    "@changesets/changelog-github",
    "@changesets/cli",
    "cz-conventional-changelog",
    "eslint-config-standard",
    "eslint-plugin-n",
    "eslint-plugin-promise",
    "typedoc-plugin-markdown",
    "tailwindcss",
    "commitizen",
    "typescript"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    "packages/basic": {
      "ignoreDependencies": ["typescript"]
    }
  }
}
