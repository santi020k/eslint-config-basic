{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "packages/playground/**",
    "typedoc.markdown.mjs"
  ],
  "ignoreDependencies": [
    "typedoc-plugin-markdown"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    ".": {
      "entry": ["config/*.mjs"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/playground/*": {
      "project": ["src/**/*.{ts,tsx,vue,svelte,astro}"]
    },
    "packages/docs": {
      "project": [".vitepress/**/*.ts", "typedoc.markdown.mjs"]
    },
    "packages/basic": {
      "ignoreDependencies": []
    },
    "packages/expo": {
      "ignoreDependencies": ["eslint-config-expo"]
    }
  }

}
