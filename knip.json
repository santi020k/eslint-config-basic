{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "packages/playground/**"
  ],
  "ignoreDependencies": [
    "typedoc-plugin-markdown",
    "tailwindcss"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    ".": {
      "entry": ["config/*.mjs", "typedoc.markdown.mjs"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/playground": {
      "project": []
    },
    "packages/playground/*": {
      "project": ["src/**/*.{js,jsx,ts,tsx,vue,svelte,astro}"]
    },
    "packages/docs": {
      "project": [".vitepress/**/*.ts"],
      "entry": []
    },
    "packages/basic": {
      "ignoreDependencies": []
    },
    "packages/expo": {
      "ignoreDependencies": ["eslint-config-expo"]
    }
  }

}
