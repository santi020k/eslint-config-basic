{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "packages/playground/**",
    "config/docs-packages.mjs",
    "typedoc.markdown.mjs"
  ],
  "ignoreDependencies": [
    "eslint-config-standard",
    "eslint-plugin-n",
    "eslint-plugin-promise",
    "typedoc-plugin-markdown",
    "tailwindcss"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    ".": {
      "entry": ["config/*.mjs"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/basic": {
      "ignoreDependencies": []
    },
    "packages/expo": {
      "ignoreDependencies": ["eslint-config-expo"]
    }
  }
}
